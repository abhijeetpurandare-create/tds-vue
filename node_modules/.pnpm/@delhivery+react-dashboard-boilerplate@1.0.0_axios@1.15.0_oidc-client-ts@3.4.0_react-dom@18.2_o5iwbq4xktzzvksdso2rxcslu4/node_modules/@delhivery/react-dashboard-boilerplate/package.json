{
  "name": "@delhivery/react-dashboard-boilerplate",
  "version": "1.0.0",
  "description": "A React authentication library for React 18+",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite --config vite.config.dev.ts",
    "build": "npm run build:lib",
    "build:lib": "tsc -p tsconfig.lib.json && vite build",
    "preview": "vite preview --config vite.config.dev.ts",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build:lib"
  },
  "keywords": [
    "ums-react",
    "ums-auth",
    "react-auth",
    "oidc",
    "keycloak"
  ],
  "author": "Delhivery",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:delhivery/react-dashboard-boilerplate.git"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.20.0",
    "axios": "^1.6.0",
    "oidc-client-ts": "^2.1.0"
  },
  "dependencies": {
    "oidc-client-ts": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "axios": "^1.6.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0"
  }
}

