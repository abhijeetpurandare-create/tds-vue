{
  "name": "@tarmac/vue",
  "version": "0.0.1",
  "description": "Vue 3 wrappers for the Tarmac Design System Web Components",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@tarmac/web-components": "workspace:*",
    "@tarmac/tokens": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "vue": "^3.5.0",
    "typescript": "^5.0.0",
    "vite": "^5.4.18",
    "vite-plugin-dts": "^4.3.0",
    "@vitejs/plugin-vue": "^5.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "@tarmac:registry": "https://npm.pkg.github.com"
  },
  "license": "ISC"
}
