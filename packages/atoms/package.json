{
  "name": "@delhivery/tarmac",
  "description": "Reausable library for react components built on react 18",
  "version": "0.0.2",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "AudioPlayer": [
        "./dist/AudioPlayer.d.ts"
      ],
      "hooks/*": [
        "./dist/hooks/*.d.ts"
      ],
      "Map": [
        "./dist/Map.d.ts"
      ],
      "MapPopup": [
        "./dist/MapPopup.d.ts"
      ],
      "MapMarker": [
        "./dist/MapMarker.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./dist/style.css": "./dist/style.css",
    "./AudioPlayer": {
      "import": "./dist/AudioPlayer.js",
      "types": "./dist/AudioPlayer.d.ts"
    },
    "./hooks/*": {
      "import": "./dist/hooks/*.js",
      "types": "./dist/hooks/*.d.ts"
    },
    "./Map": {
      "import": "./dist/Map.js",
      "types": "./dist/Map.d.ts"
    },
    "./MapPopup": {
      "import": "./dist/MapPopup.js",
      "types": "./dist/MapPopup.d.ts"
    },
    "./MapMarker": {
      "import": "./dist/MapMarker.js",
      "types": "./dist/MapMarker.d.ts"
    },
    "./tailwind-preset": {
      "require": "./dist/tailwind-preset.cjs",
      "default": "./dist/tailwind-preset.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "nodemon --watch src --ext ts,tsx,js,jsx,css,scss --ignore src/index.ts --ignore src/index.ts.backup --exec \"node build-dev.cjs\"",
    "build:css": "postcss src/index.css -o dist/style.css",
    "build": "pnpm run build:css && vite build && node scripts/generate-tailwind-preset.cjs",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev:server": "vite --port 3000",
    "test:watch": "jest --watch",
    "test": "jest --config=jest.config.mjs",
    "generate-props-manifest": "node scripts/generate-props-manifest.cjs",
    "coverage": "jest --config=jest.config.coverage.mjs && npx serve -s coverage/lcov-report -l 3000 & (sleep 1 && open-cli http://localhost:3000 || start http://localhost:3000)"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/delhivery/Tarmac-Design-System",
    "directory": "packages/atoms"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/delhivery/Tarmac-Design-System/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "@delhivery:registry": "https://npm.pkg.github.com"
  },
  "homepage": "https://delhivery.github.io/Tarmac-Design-System",
  "dependencies": {
    "@emotion/css": "^11.11.2",
    "@fortawesome/fontawesome-svg-core": "^7.0.0",
    "@fortawesome/free-regular-svg-icons": "^7.0.0",
    "@fortawesome/free-solid-svg-icons": "^7.0.0",
    "@fortawesome/react-fontawesome": "^0.2.3",
    "@headlessui/react": "^2.2.1",
    "@tailwindcss/vite": "^4.0.17",
    "@turf/turf": "^7.3.4",
    "@types/node": "^24.1.0",
    "clsx": "^2.1.1",
    "maplibre-gl": "4.7.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-map-gl": "8.0.4",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "eslint": "^8.40.0",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nodemon": "^3.1.9",
    "open-cli": "^8.0.0",
    "postcss": "^8.5.10",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.0",
    "react-docgen-typescript": "^2.4.0",
    "rimraf": "^4.4.1",
    "tailwindcss": "3.4.17",
    "ts-jest": "^29.3.1",
    "typescript": "^5.0.0",
    "vite": "^5.4.18",
    "vite-plugin-dts": "^4.3.0",
    "wait-on": "^8.0.3"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}